<div class="cyberpunk cyberpunk-card flexcol">
    <h2>{{#if action.name}}{{action.name}}{{else}}{{CPLocal "Attack"}}{{/if}}</h2>
    <div class="field-list one-col">
        <div class="field">
            <span>{{CPLocal "Attacker"}}: </span>
            <span class="flex-pad">{{attacker.name}}</span>
        </div>
        {{#if weapon.name}}
        <div class="field">
            <span>{{CPLocal "Weapon"}}: </span>
            <span class="flex-pad">{{weapon.name}}</span>
        </div>
        {{/if}}
        {{#if action.fireMode}}
        <div class="field">
            <span>{{CPLocal "FireMode"}}: </span>
            <span class="flex-pad">{{CPLocal action.fireMode}}</span>
        </div>
        {{/if}}
    </div>

    {{#if action.modifiers.length}}
    <div class="field-list one-col section-divider">
        <div class="field">
            <strong>{{CPLocal "AttackModifiers"}}:</strong>
        </div>
        {{#each action.modifiers as |mod|}}
        <div class="field">
            <span>{{mod.label}}: </span>
            <span class="flex-pad">{{mod.value}}</span>
        </div>
        {{/each}}
    </div>
    {{/if}}

    {{#each targets as |targetOutcome|}}
        <div class="field-list one-col section-divider">
            <div class="field">
                <span>{{CPLocal "Target"}}: </span>
                <span class="flex-pad">{{targetOutcome.target.name}}</span>
            </div>
            {{#if targetOutcome.damage}}
            <div class="field target-total-damage">
                <span>Total: </span>
                <span class="total-damage-delta flex-pad">{{targetOutcome.damage.damageDelta}} wd</span>
                <span class="wound-state-from">{{targetOutcome.damage.previousWoundState.label}}</span>
                <span class="wound-arrow"> → </span>
                <span class="wound-state-to {{#if targetOutcome.damage.crossedThreshold}}wound-state-escalated{{/if}}">{{targetOutcome.damage.nextWoundState.label}}</span>
            </div>
            {{/if}}
            {{#if (hasProperty targetOutcome.attack "total")}}
                <div class="field">
                    <span>{{CPLocal "Attack"}}: </span>
                    <span class="attack-total">{{targetOutcome.attack.total}}</span>
                    <span class="flex-pad"></span>
                    <span class="roll-results">
                        {{#if targetOutcome.attack.die.natural}}
                            {{#if targetOutcome.attack.die.results}}
                                {{#each targetOutcome.attack.die.results as |r|}}
                                    <span class="roll-result roll die">{{r}}</span>
                                {{/each}}
                            {{else}}
                                <span class="roll-result roll die">{{targetOutcome.attack.die.natural}}</span>
                            {{/if}}
                        {{else}}
                            {{#each targetOutcome.attack.die.subrolls as |subroll|}}
                                <span class="roll-result roll die {{subroll.classes}}">{{subroll.result}}</span>
                            {{/each}}
                        {{/if}}
                    </span>
                </div>
                {{#if targetOutcome.attack.targetNumber}}
                <div class="field">
                    <span>{{CPLocal "ToHit"}} (DC): </span>
                    <span class="flex-pad">{{targetOutcome.attack.targetNumber}}</span>
                </div>
                {{/if}}
                {{#if (hasProperty targetOutcome.attack "roundsFired")}}
                <div class="field">
                    <span>{{CPLocal "RoundsFired"}}: </span>
                    <span class="flex-pad">{{targetOutcome.attack.roundsFired}}</span>
                </div>
                {{/if}}
                {{#if (hasProperty targetOutcome.attack "roundsFiredPerTarget")}}
                <div class="field">
                    <span>{{CPLocal "RoundsPerTarget"}}: </span>
                    <span class="flex-pad">{{targetOutcome.attack.roundsFiredPerTarget}}</span>
                </div>
                {{/if}}
                {{#if (hasProperty targetOutcome.attack "hitCount")}}
                <div class="field">
                    <span>{{CPLocal "HitCount"}}: </span>
                    <span class="flex-pad">{{targetOutcome.attack.hitCount}}</span>
                </div>
                {{/if}}
                {{#if targetOutcome.attack.modifiers.length}}
                <div class="field">
                    <strong>{{CPLocal "AttackModifiers"}}:</strong>
                </div>
                    {{#each targetOutcome.attack.modifiers as |mod|}}
                    <div class="field">
                        <span>{{mod.label}}: </span>
                        <span class="flex-pad">{{mod.value}}</span>
                    </div>
                    {{/each}}
                {{/if}}
                <div class="field">
                    <span>{{CPLocal "Result"}}: </span>
                    <span class="flex-pad">
                        {{#if targetOutcome.attack.notFired}}
                            <strong class="outcome-not-fired">{{CPLocal "NotFired"}}</strong>
                        {{else if targetOutcome.attack.hit}}
                            <strong class="outcome-hit">{{CPLocal "Hit"}}</strong>
                        {{else}}
                            <strong class="outcome-miss">{{CPLocal "Miss"}}</strong>
                        {{/if}}
                    </span>
                </div>
                {{#if targetOutcome.attack.hit}}
                    {{#if targetOutcome.attack.burstHitsRoll}}
                    <div class="field">
                        <span>{{CPLocal "ThreeRoundBurst"}}: </span>
                        <span class="flex-pad">{{targetOutcome.attack.burstHitsRoll.total}}</span>
                    </div>
                    {{/if}}
                    {{#each targetOutcome.hits as |hit|}}
                    <details class="hit-block" {{#if @first}}open{{/if}}>
                        <summary class="hit-summary">
                            <span class="hit-location-label">{{CPLocal hit.location}}</span>
                            <span class="flex-pad"></span>
                            {{#if (hasProperty hit "finalDamage")}}
                            <span class="hit-final-damage">{{hit.finalDamage}} dmg</span>
                            {{/if}}
                            {{#if hit.woundTransition.crossedThreshold}}
                            <span class="wound-crossed-badge">⚠ {{hit.woundTransition.nextWoundState.label}}</span>
                            {{/if}}
                        </summary>

                        {{!-- Damage pipeline --}}
                        <div class="damage-pipeline">
                            {{#if hit.damageRoll}}
                            <div class="pipeline-row">
                                <span class="pipeline-label">{{CPLocal "Damage"}}</span>
                                <span class="pipeline-value">{{hit.damageRoll.total}}</span>
                                {{#if hit.damageRoll.formula}}<span class="formula-text">({{hit.damageRoll.formula}})</span>{{/if}}
                                <span class="flex-pad"></span>
                                <span class="roll-results">
                                    {{#each hit.damageRoll.die.subrolls as |subroll|}}
                                        <span class="roll-result roll die {{subroll.classes}}">{{subroll.result}}</span>
                                    {{/each}}
                                </span>
                            </div>
                            {{/if}}
                            {{#if hit.shotgun}}
                            <div class="pipeline-row">
                                <span class="pipeline-label">{{CPLocal "Shotgun"}}</span>
                                <span class="pipeline-value">{{hit.shotgun.bracket}} / {{hit.shotgun.damageFormula}} / {{hit.shotgun.patternWidthMeters}}m</span>
                            </div>
                            <div class="pipeline-row">
                                <span class="pipeline-label">Template</span>
                                <span class="pipeline-value">{{hit.shotgun.inclusion}} {{#if hit.shotgun.templateId}}({{hit.shotgun.templateId}}){{/if}}</span>
                            </div>
                            {{#if hit.shotgun.measuredDistance}}
                            <div class="pipeline-row">
                                <span class="pipeline-label">Distance</span>
                                <span class="pipeline-value">{{hit.shotgun.measuredDistance.value}}{{hit.shotgun.measuredDistance.units}}</span>
                            </div>
                            {{/if}}
                            {{/if}}
                            {{#if (hasProperty hit "rawDamage")}}
                            <div class="pipeline-row">
                                <span class="pipeline-label">{{CPLocal "RawDamage"}}</span>
                                <span class="pipeline-value">{{hit.rawDamage}}</span>
                            </div>
                            {{/if}}
                            {{#if hit.cover.provided}}
                            <div class="pipeline-row pipeline-cover">
                                <span class="pipeline-label">{{CPLocal "HitCover"}} ({{hit.cover.effectiveStoppingPower}} SP)</span>
                                <span class="pipeline-value flex-pad">
                                    {{#if hit.cover.bypassed}}
                                        <strong class="outcome-miss">{{CPLocal "CoverBypassed"}}</strong>
                                    {{else}}
                                        {{#if hit.cover.penetrated}}
                                            <strong class="outcome-hit">{{CPLocal "CoverPenetrated"}}</strong> ({{hit.rawDamage}} {{CPLocal "vs"}} {{hit.cover.effectiveStoppingPower}} SP)
                                        {{else}}
                                            <strong class="outcome-miss">{{CPLocal "CoverStoppedAttack"}}</strong>
                                        {{/if}}
                                    {{/if}}
                                </span>
                            </div>
                            {{#if hit.cover.protectedLocations}}
                            <div class="pipeline-row">
                                <span class="pipeline-label">{{CPLocal "CoverProtectedLocations"}}</span>
                                <span class="pipeline-value flex-pad">{{#each hit.cover.protectedLocations as |location|}}{{#unless @first}}, {{/unless}}{{CPLocal location}}{{/each}}</span>
                            </div>
                            {{/if}}
                            <div class="pipeline-row pipeline-mitigation">
                                <span class="pipeline-label">{{CPLocal "CoverMitigation"}}</span>
                                <span class="pipeline-value">{{hit.cover.mitigation}}</span>
                            </div>
                            {{#if hit.cover.ablation}}
                            <div class="pipeline-row">
                                <span class="pipeline-label">{{CPLocal "CoverAblation"}}</span>
                                <span class="pipeline-value">
                                    {{#if hit.cover.ablation.applied}}
                                        {{hit.cover.ablation.before}} → {{hit.cover.ablation.after}}
                                    {{else}}
                                        {{hit.cover.ablation.before}}
                                    {{/if}}
                                </span>
                            </div>
                            {{/if}}
                            {{/if}}
                            {{#if hit.stagedPenetration}}
                            {{#if (compare hit.stagedPenetration.reason "===" "stress")}}
                            <div class="pipeline-row pipeline-stress-warning">
                                <span>Outer Layer Stressed! {{hit.stagedPenetration.layer.name}} takes 1 Ablation (Damage exceeded raw SP).</span>
                            </div>
                            {{/if}}
                            {{/if}}
                            {{#if (hasProperty hit "armorMitigation")}}
                            <div class="pipeline-row pipeline-mitigation">
                                <span class="pipeline-label">{{CPLocal "Armor"}}{{#if hit.armorPiercing}} (AP){{/if}}</span>
                                <span class="pipeline-value">-{{hit.armorMitigation}}</span>
                                {{#if (hasProperty hit "effectiveStoppingPower")}}<span class="formula-text">{{hit.effectiveStoppingPower}} SP</span>{{/if}}
                            </div>
                            {{/if}}
                            {{#if (hasProperty hit "bodyTypeMitigation")}}
                            {{#if (compare hit.bodyTypeMitigation "!==" null)}}
                            <div class="pipeline-row pipeline-mitigation">
                                <span class="pipeline-label">{{CPLocal "BTMShort"}}</span>
                                <span class="pipeline-value">{{hit.bodyTypeMitigation}}</span>
                            </div>
                            {{/if}}
                            {{/if}}
                            {{#if (hasProperty hit "finalDamage")}}
                            <div class="pipeline-row pipeline-final">
                                <span class="pipeline-label">{{CPLocal "FinalDamage"}}</span>
                                <span class="pipeline-value final-damage-value">{{hit.finalDamage}}</span>
                            </div>
                            {{/if}}
                        </div>

                        {{!-- Special cases: head doubling, limb loss --}}
                        {{#each hit.specialCases as |sc|}}
                        <div class="special-case-alert special-case-{{sc.code}}">
                            {{#if (compare sc.code "===" "head-hit-double-damage")}}
                                ⚡ HEAD HIT: {{sc.damageBeforeMultiplier}} × 2 = {{sc.damageAfterMultiplier}}
                            {{else if (compare sc.code "===" "head-critical-injury")}}
                                ☠ HEAD CRITICAL: &gt;{{sc.threshold}} dmg — instant kill unless overridden
                            {{else if (compare sc.code "===" "limb-loss-threshold")}}
                                ✂ LIMB LOSS THRESHOLD: &gt;{{sc.threshold}} dmg — limb severed or crushed
                            {{else}}
                                ⚡ {{sc.code}}
                            {{/if}}
                        </div>
                        {{/each}}

                        {{!-- Wound state transition --}}
                        {{#if hit.woundTransition}}
                        <div class="wound-transition {{#if hit.woundTransition.crossedThreshold}}wound-crossed{{/if}}">
                            <span class="wound-label">{{CPLocal "WoundDamage"}}:</span>
                            <span class="wound-delta">{{hit.woundDamage}}</span>
                            <span class="wound-state-from">{{hit.woundTransition.previousWoundState.label}}</span>
                            <span class="wound-arrow"> → </span>
                            <span class="wound-state-to {{#if hit.woundTransition.crossedThreshold}}wound-state-escalated{{/if}}">{{hit.woundTransition.nextWoundState.label}}</span>
                        </div>
                        {{/if}}

                        {{!-- SDP transition (Full Body Conversion actors) --}}
                        {{#if hit.sdpTransition}}
                        <div class="wound-transition">
                            <span class="wound-label">{{hit.sdpTransition.locationLabel}} SDP:</span>
                            <span class="wound-state-from">{{hit.sdpTransition.previousSdp}}</span>
                            <span class="wound-arrow"> → </span>
                            <span class="wound-state-to">{{hit.sdpTransition.nextSdp}}</span>
                        </div>
                        {{/if}}

                        {{!-- Hit-level warnings --}}
                        {{#if hit.warnings.length}}
                        <div class="warnings warning-block">
                            {{#each hit.warnings as |w|}}<div>{{w.message}}</div>{{/each}}
                        </div>
                        {{/if}}
                    </details>
                    {{/each}}

                    {{!-- Save prompts (Stun / Death) --}}
                    {{#if targetOutcome.saves.length}}
                    <div class="saves-block field-list one-col">
                        <div class="field"><strong>Saves Required:</strong></div>
                        {{#each targetOutcome.saves as |save|}}
                        <div class="field save-prompt save-{{save.type}}">
                            <span>{{save.type}} Save: </span>
                            <span class="flex-pad">BT{{save.bodyType}} − {{save.penalty}} = {{save.threshold}}+</span>
                            {{#if (compare save.type "===" "death")}}
                            <span class="formula-text">(Mortal {{save.mortalLevel}})</span>
                            {{/if}}
                        </div>
                        {{/each}}
                        {{#if isCommitted}}
                        <div class="save-actions flexrow" style="gap: 5px; margin-top: 5px;">
                            <button class="save-action-autoroll" data-target-uuid="{{targetOutcome.target.actorUuid}}">Auto-roll Saves (NPC)</button>
                            <button class="save-action-manual" data-target-uuid="{{targetOutcome.target.actorUuid}}">Resolve Manually</button>
                        </div>
                        {{/if}}
                    </div>
                    {{/if}}
                {{/if}}
            {{/if}}
        </div>
    {{/each}}

    {{#if (hasProperty ammo "delta")}}
    <div class="field-list one-col section-divider">
        <div class="field">
            <span>{{CPLocal "AmmoDelta"}}: </span>
            <span class="flex-pad">{{ammo.delta}} ({{ammo.after}} / {{ammo.before}})</span>
        </div>
    </div>
    {{/if}}

    {{#if warnings.length}}
        <div class="warnings warning-block">
            <strong>{{CPLocal "Warnings"}}:</strong>
            <ul>
                {{#each warnings as |warning|}}
                    <li>{{warning.message}}</li>
                {{/each}}
            </ul>
        </div>
    {{/if}}

    <div class="status-banner status-{{status}}">
        {{#if isPreview}}
            <span>{{CPLocal "PreviewStatus"}} - {{CPLocal "PreviewStatusDesc"}}</span>
        {{/if}}
        {{#if isCommitted}}
            <span>{{CPLocal "CommittedStatus"}} - {{CPLocal "CommittedStatusDesc"}}</span>
        {{/if}}
        {{#if isCanceled}}
            <span>{{CPLocal "CanceledStatus"}} - {{CPLocal "CanceledStatusDesc"}}</span>
        {{/if}}
        {{#if isManual}}
            <span>{{CPLocal "ManualStatus"}} - {{CPLocal "ManualStatusDesc"}}</span>
            {{#if manualResolution.reason}}
                <span class="manual-reason">({{manualResolution.reason}})</span>
            {{/if}}
            {{#if manualResolution.message}}
                <div class="manual-message">{{manualResolution.message}}</div>
            {{/if}}
        {{/if}}
    </div>
</div>
