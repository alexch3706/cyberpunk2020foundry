{{!-- Container for all the stats --}}
<div class="stats flexrow" style="width: 100%; align-items: center; justify-content: space-between;">
    <div class="footer-stats" style="display: flex; flex-wrap: wrap; gap: 5px; width: 100%;">
        {{#each system.stats as |stat key|}}
        {{#unless (or (equals key "save") (equals key "bt") (equals key "ma") (equals key "emp"))}}
        <div class="footer-stat field stat" style="display: flex; align-items: center; background: #12121a; border: 1px solid #1a1a28; padding: 2px 5px;">
            <label style="color: #ff2d7b; font-weight: bold; margin-right: 5px;">{{localize (localizeStat key)}}</label>
            <div class="stat-inputs" style="display: flex; gap: 2px;">
                <input type="number" name="system.stats.{{key}}.base" value="{{stat.base}}" class="stat-base" style="width: 20px; background: transparent; border: none; color: #e0e0e8; font-family: monospace; text-align: right;"/>
                <span style="color: #667788;">+</span>
                <input class="stat-temp" type="number" name="system.stats.{{key}}.tempMod" value="{{stat.tempMod}}" style="width: 20px; background: transparent; border: none; color: #e0e0e8; font-family: monospace;"/>
            </div>
            <input class="stat-total action stat-roll val" data-stat-name="{{key}}" value="{{stat.total}}" readonly style="background: transparent; border: none; width: 25px; text-align: center; cursor: pointer; color: #00e5ff; font-weight: bold;">
        </div>
        {{/unless}}
        {{/each}}
        
        {{!-- MA Stats --}}
        <div class="footer-stat field stat" style="display: flex; align-items: center; background: #12121a; border: 1px solid #1a1a28; padding: 2px 5px;">
            <label style="color: #ff2d7b; font-weight: bold; margin-right: 5px;">MA</label>
            <div class="stat-inputs" style="display: flex; gap: 2px;">
                <input type="number" name="system.stats.ma.base" value="{{system.stats.ma.base}}" class="stat-base" style="width: 20px; background: transparent; border: none; color: #e0e0e8; font-family: monospace; text-align: right;"/>
                <span style="color: #667788;">+</span>
                <input class="stat-temp" type="number" name="system.stats.ma.tempMod" value="{{system.stats.ma.tempMod}}" style="width: 20px; background: transparent; border: none; color: #e0e0e8; font-family: monospace;"/>
            </div>
            <input class="stat-total action stat-roll val" data-stat-name="ma" value="{{system.stats.ma.total}}" readonly style="background: transparent; border: none; width: 25px; text-align: center; cursor: pointer; color: #00e5ff; font-weight: bold;">
        </div>

        {{!-- EMP / Humanity --}}
        <div class="footer-stat field stat" style="display: flex; align-items: center; background: #12121a; border: 1px solid #1a1a28; border-left: 2px solid #ff2d7b; padding: 2px 5px;">
            <label style="color: #ff2d7b; font-weight: bold; margin-right: 5px;">EMP</label>
            <div class="stat-inputs" style="display: flex; gap: 2px;">
                <input type="number" name="system.stats.emp.base" value="{{system.stats.emp.base}}" class="stat-base" style="width: 20px; background: transparent; border: none; color: #e0e0e8; font-family: monospace; text-align: right;"/>
                <span style="color: #667788;">+</span>
                <input class="stat-temp" type="number" name="system.stats.emp.tempMod" value="{{system.stats.emp.tempMod}}" style="width: 20px; background: transparent; border: none; color: #e0e0e8; font-family: monospace;"/>
            </div>
            <input class="stat-total action stat-roll val" data-stat-name="emp" value="{{system.stats.emp.total}}" readonly style="background: transparent; border: none; width: 25px; text-align: center; cursor: pointer; color: #00e5ff; font-weight: bold;">
        </div>
        <div class="footer-stat field" style="display: flex; align-items: center; background: transparent; padding: 2px 5px;">
            <label title="{{CPLocal "Humanity"}}" style="color: #ff2d7b; font-weight: bold; margin-right: 5px;">HUM</label>
            <input type="text" class="val not-editable" value="{{system.stats.emp.humanity.total}}/{{system.stats.emp.humanity.base}}" readonly style="width: 45px; color: #e0e0e8; background: transparent; border: none; font-family: monospace;">
        </div>
    </div>
</div>
