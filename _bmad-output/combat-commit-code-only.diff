+<div class="cyberpunk cyberpunk-card flexcol">
+    <h2>{{#if action.name}}{{action.name}}{{else}}{{CPLocal "Attack"}}{{/if}}</h2>
+    <div class="field-list one-col">
+        <div class="field">
+            <span>{{CPLocal "Attacker"}}: </span>
+            <span class="flex-pad">{{attacker.name}}</span>
+        </div>
+        {{#if weapon.name}}
+        <div class="field">
+            <span>{{CPLocal "Weapon"}}: </span>
+            <span class="flex-pad">{{weapon.name}}</span>
+        </div>
+        {{/if}}
+        {{#if action.fireMode}}
+        <div class="field">
+            <span>{{CPLocal "FireMode"}}: </span>
+            <span class="flex-pad">{{CPLocal action.fireMode}}</span>
+        </div>
+        {{/if}}
+    </div>
+    
+    {{#each targets as |targetOutcome|}}
+        <div class="field-list one-col" style="margin-top: 5px; border-top: 1px solid #c00; padding-top: 5px;">
+            <div class="field">
+                <span>{{CPLocal "Target"}}: </span>
+                <span class="flex-pad">{{targetOutcome.target.name}}</span>
+            </div>
+            {{#if targetOutcome.attack.total}}
+                <div class="field">
+                    <span>{{CPLocal "Attack"}}: </span>
+                    <span>{{targetOutcome.attack.total}}</span>
+                    <span class="flex-pad"></span>
+                    <span class="roll-results">
+                        {{#each targetOutcome.attack.die.subrolls as |subroll|}}
+                            <span class="roll-result roll die {{subroll.classes}}">{{subroll.result}}</span>
+                        {{/each}}
+                    </span>
+                </div>
+                {{#if targetOutcome.attack.targetNumber}}
+                <div class="field">
+                    <span>{{CPLocal "ToHit"}} (DC): </span>
+                    <span class="flex-pad">{{targetOutcome.attack.targetNumber}}</span>
+                </div>
+                {{/if}}
+                <div class="field">
+                    <span>{{CPLocal "Result"}}: </span>
+                    <span class="flex-pad">
+                        {{#if targetOutcome.attack.hit}}
+                            <strong style="color: #0f0; text-transform: uppercase;">{{CPLocal "Hit"}}</strong>
+                        {{else}}
+                            <strong style="color: #f00; text-transform: uppercase;">{{CPLocal "Miss"}}</strong>
+                        {{/if}}
+                    </span>
+                </div>
+                {{#if targetOutcome.attack.hit}}
+                    {{#each targetOutcome.hits as |hit|}}
+                        <div class="field">
+                            <span>{{CPLocal "HitLocation"}}: </span>
+                            <span class="flex-pad">{{CPLocal hit.location}}</span>
+                        </div>
+                    {{/each}}
+                {{/if}}
+            {{/if}}
+        </div>
+    {{/each}}
+    
+    {{#if ammo.delta}}
+    <div class="field-list one-col" style="margin-top: 5px; border-top: 1px solid #c00; padding-top: 5px;">
+        <div class="field">
+            <span>{{CPLocal "Ammo"}} Delta: </span>
+            <span class="flex-pad">{{ammo.delta}} ({{ammo.after}} / {{ammo.before}})</span>
+        </div>
+    </div>
+    {{/if}}
+
+    {{#if warnings.length}}
+        <div class="warnings" style="color: #ffaa00; margin-top: 5px; font-size: 0.9em; border-top: 1px solid #ffaa00; padding-top: 5px;">
+            <strong>Warnings:</strong>
+            <ul style="margin: 3px 0; padding-left: 15px;">
+                {{#each warnings as |warning|}}
+                    <li>{{warning.message}}</li>
+                {{/each}}
+            </ul>
+        </div>
+    {{/if}}
+
+    <div class="status-banner status-{{status}}" style="margin-top: 10px; padding: 5px; text-align: center; font-weight: bold; border: 1px solid;">
+        {{#if isPreview}}
+            <span style="color: #3498db; border-color: #3498db;">[PREVIEW] - Pending Confirmation</span>
+        {{/if}}
+        {{#if isCommitted}}
+            <span style="color: #2ecc71; border-color: #2ecc71;">[COMMITTED] - Applied to Actor(s)</span>
+        {{/if}}
+        {{#if isCanceled}}
+            <span style="color: #e74c3c; border-color: #e74c3c;">[CANCELED] - Discarded</span>
+        {{/if}}
+        {{#if isManual}}
+            <span style="color: #f1c40f; border-color: #f1c40f;">[MANUAL] - Requires GM Resolution</span>
+        {{/if}}
+    </div>
+</div>
